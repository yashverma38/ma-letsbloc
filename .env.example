# Copy to .env.local and fill in.
# Never commit .env.local.

# OpenCode (Gemini vision + translation).
# Endpoint: https://opencode.ai/zen/v1/chat/completions (OpenAI-compatible).
# Model used: gemini-3-flash
OPENCODE_API_KEY=

# Sarvam (Indian voice TTS, bulbul:v2).
# Endpoint: https://api.sarvam.ai/text-to-speech
SARVAM_API_KEY=

# Supabase — voice_notes + audio storage (waitlist is in Firestore)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Firebase client — safe to expose but prefer env vars
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Public site URL (used for share links)
NEXT_PUBLIC_SITE_URL=https://ma.letsbloc.com

# Mixpanel — funnel analytics (signup → screenshot → voice note → awareness → bloc)
NEXT_PUBLIC_MIXPANEL_TOKEN=
