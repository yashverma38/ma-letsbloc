# Copy to .env.local and fill in.
# Never commit .env.local.

# Google Gemini (Vision + text)
GEMINI_API_KEY=

# ElevenLabs (voice synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Supabase (persistence + storage)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Public site URL (used for share links)
NEXT_PUBLIC_SITE_URL=https://ma.letsbloc.com
