# Copy to .env.local and fill in.
# Never commit .env.local.

# OpenCode (routes Gemini Vision via the community AI SDK provider).
# Credentials are configured through the OpenCode CLI, not this file.
# See https://ai-sdk.dev/providers/community-providers/opencode-sdk

# ElevenLabs — voice synthesis
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Supabase — voice_notes + audio storage only (waitlist lives in Firestore)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Firebase (client-side SDK, safe to expose but still prefer env vars)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Public site URL (used in share links)
NEXT_PUBLIC_SITE_URL=https://ma.letsbloc.com
